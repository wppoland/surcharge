#. Plugin Name of the plugin
#: surcharge.php
msgid "Surcharge - Checkout Fees for WooCommerce"
msgstr "Surcharge - Opłaty przy zamówieniu dla WooCommerce"

#. Plugin URI of the plugin
#: surcharge.php
msgid "https://plogins.com/surcharge/"
msgstr "https://plogins.com/surcharge/"

#. Description of the plugin
#: surcharge.php
msgid "Add fixed or percentage fees to the WooCommerce cart and checkout."
msgstr "Dodawaj opłaty stałe lub procentowe do koszyka i zamówienia w WooCommerce."

#. Author of the plugin
#: surcharge.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: surcharge.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: src/Admin/Settings.php:62
#: src/Admin/Settings.php:63
msgid "Surcharge"
msgstr "Opłaty"

#: src/Admin/Settings.php:101
msgid "Active"
msgstr "Aktywne"

#: src/Admin/Settings.php:103
msgid "Disabled"
msgstr "Wyłączone"

#: src/Admin/Settings.php:110
msgid "Add checkout fees in two steps"
msgstr "Dodaj opłaty przy zamówieniu w dwóch krokach"

#: src/Admin/Settings.php:111
msgid "1. Add a fee row below. 2. Choose a fixed amount or a percentage of the cart. Fees appear in the cart, at checkout and on the order."
msgstr "1. Dodaj wiersz opłaty poniżej. 2. Wybierz kwotę stałą lub procent wartości koszyka. Opłaty pojawiają się w koszyku, przy składaniu zamówienia oraz na zamówieniu."

#: src/Admin/Settings.php:119
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:124
msgid "Enable fees"
msgstr "Włącz opłaty"

#: src/Admin/Settings.php:129
msgid "Apply the fees below at cart and checkout."
msgstr "Stosuj poniższe opłaty w koszyku i przy zamówieniu."

#: src/Admin/Settings.php:131
msgid "Master switch. When off, no fees are added to any cart, regardless of the rows below."
msgstr "Przełącznik główny. Po wyłączeniu żadne opłaty nie są dodawane do koszyka, niezależnie od poniższych wierszy."

#: src/Admin/Settings.php:140
msgid "Fees"
msgstr "Opłaty"

#: src/Admin/Settings.php:141
msgid "Each row is one fee. A fee with no label is skipped."
msgstr "Każdy wiersz to jedna opłata. Opłata bez etykiety jest pomijana."

#: src/Admin/Settings.php:145
#: src/Admin/Settings.php:159
msgid "Add fee"
msgstr "Dodaj opłatę"

#: src/Admin/Settings.php:187
msgid "Fee"
msgstr "Opłata"

#: src/Admin/Settings.php:191
msgid "Label"
msgstr "Etykieta"

#: src/Admin/Settings.php:192
msgid "e.g. Handling fee"
msgstr "np. Opłata manipulacyjna"

#: src/Admin/Settings.php:196
msgid "Type"
msgstr "Typ"

#: src/Admin/Settings.php:198
msgid "Fixed amount"
msgstr "Kwota stała"

#: src/Admin/Settings.php:199
msgid "Percentage of cart"
msgstr "Procent wartości koszyka"

#: src/Admin/Settings.php:204
msgid "Amount"
msgstr "Kwota"

#: src/Admin/Settings.php:211
msgid "Taxable"
msgstr "Opodatkowana"

#: src/Admin/Settings.php:219
msgid "Enabled"
msgstr "Włączona"

#: src/Admin/Settings.php:221
msgid "Remove fee"
msgstr "Usuń opłatę"

#: surcharge.php:47
msgid "Surcharge - Checkout Fees for WooCommerce requires WooCommerce to be active."
msgstr "Surcharge - Opłaty przy zamówieniu dla WooCommerce wymaga aktywnej wtyczki WooCommerce."
